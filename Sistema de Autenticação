senha_correta = "54321"
tentativas = 3

while tentativas > 0 :
    senha = input("Digite a Senha: ")

    if senha == senha_correta:
        print("Acesso Liberado!!!")
        break
    else:
        tentativas -= 1
        print(f"Senha Incorreta. Tentativas Restantes: {tentativas}")

if tentativas == 0 :
    print("Acesso Negado. Tentativas Esgotadas")
